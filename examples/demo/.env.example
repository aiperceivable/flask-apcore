# Flask
FLASK_APP=app.py
FLASK_DEBUG=0

# MCP Server
APCORE_SERVE_TRANSPORT=streamable-http
APCORE_SERVE_HOST=127.0.0.1
APCORE_SERVE_PORT=9100
# APCORE_SERVER_VERSION=1.0.0

# Module Filtering
# APCORE_SERVE_TAGS=api,analytics
# APCORE_SERVE_PREFIX=task

# Observability
APCORE_TRACING_ENABLED=true
APCORE_TRACING_EXPORTER=stdout
APCORE_METRICS_ENABLED=true
APCORE_LOGGING_ENABLED=true
APCORE_LOGGING_FORMAT=json

# System Modules (apcore 0.11.0+)
# APCORE_SYS_MODULES_ENABLED=true
# APCORE_SYS_MODULES_EVENTS_ENABLED=true

# JWT Authentication (optional, HTTP transports only)
# APCORE_SERVE_JWT_SECRET=change-me-in-production
# APCORE_SERVE_JWT_ALGORITHM=HS256
# APCORE_SERVE_JWT_AUDIENCE=task-manager
# APCORE_SERVE_JWT_ISSUER=https://auth.example.com
# APCORE_SERVE_REQUIRE_AUTH=true
# APCORE_SERVE_EXEMPT_PATHS=/health,/explorer

# Approval (apcore-mcp 0.8.0+)
# APCORE_SERVE_APPROVAL=elicit

# Output Formatter (apcore-mcp 0.10.0+)
# APCORE_SERVE_OUTPUT_FORMATTER=apcore_toolkit.to_markdown

# Explorer UI
# APCORE_SERVE_EXPLORER=true
# APCORE_SERVE_EXPLORER_PREFIX=/explorer
# APCORE_SERVE_ALLOW_EXECUTE=true
# APCORE_SERVE_EXPLORER_TITLE=Task Manager Tools
# APCORE_SERVE_EXPLORER_PROJECT_NAME=flask-apcore demo
# APCORE_SERVE_EXPLORER_PROJECT_URL=https://github.com/aipartnerup/flask-apcore

# Scan Options
# APCORE_SCAN_AI_ENHANCE=false
# APCORE_SCAN_VERIFY=false
